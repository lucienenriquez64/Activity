<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Simple Portfolio</title>
</head>
<body style="
    font-family: Arial, sans-serif;
    text-align: center;
    margin: 0;
    padding: 40px;
    background: linear-gradient(to right, #1100ff, #1100ff);
  ">

  <!-- Header -->
  <h1 style="color: #fbff00; font-size: 42px;">
    Lucien Enriquez
  </h1>

  <!-- Profile Picture -->
  <img 
    src="./images/profile.png" 
    alt="Profile Picture"
    style="
      width: 200px;
      height: 200px;
      border-radius: 50%;
      object-fit: cover;
      border: 5px solid #ff0000;
      margin-top: 20px;
      box-shadow: 0 4px 10px rgba(0,0,0,0.2);
    "
  />

  <!-- Portfolio Description -->
  <p style="
      max-width: 600px;
      margin: 30px auto;
      font-size: 18px;
      line-height: 1.6;
      color: #374151;
      background-color: rgb(255, 0, 0);
      padding: 20px;
      border-radius: 10px;
    ">
    Hello! I am a first year IT student who enjoys gaming. I'm looking forward to learn new things such as improving coding skills and enhancing problem-solving skills in this course.
  </p>

  <!-- Hobbies List -->
  <ul style="
      list-style: none;
      padding: 0;
      margin: 0 auto;
      font-size: 18px;
      color: #ff0000;
      background-color: rgb(251, 255, 0);
      display: inline-block;
      padding: 20px 40px;
      border-radius: 10px;
    ">
    <li style="margin: 10px 0;">Chatting with Friends</li>
    <li style="margin: 10px 0;">Playing Video Games</li>
    <li style="margin: 10px 0;">Streaming</li>
  </ul>

</body>
</html>
